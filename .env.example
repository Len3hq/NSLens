# ============================================================
# NSLens / Network Brain — Environment Variables
# Copy this file to .env and fill in your values.
# The API server reads variables directly from the environment.
# The web frontend reads VITE_* variables at build time.
# ============================================================


# ------------------------------------------------------------
# SERVER
# ------------------------------------------------------------

# Port the Express API server listens on (required)
PORT=8080

# Set to "production" to enable production-only behaviour:
#   - /api/dev/seed and /api/dev/seed/clear are disabled
#   - Clerk proxy middleware activates
#   - Pino outputs structured JSON (no pretty-print)
NODE_ENV=development

# Pino log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info


# ------------------------------------------------------------
# DATABASE  (PostgreSQL with pgvector extension required)
# ------------------------------------------------------------
# Supported providers: Neon, Supabase, Railway, local Docker, etc.
# Must have pgvector installed: CREATE EXTENSION IF NOT EXISTS vector;

DATABASE_URL=postgresql://user:password@host:5432/dbname


# ------------------------------------------------------------
# AUTHENTICATION  (Discord OAuth + NS Auth)
# ------------------------------------------------------------

# Discord application credentials — create at discord.com/developers
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# The exact redirect URI registered in your Discord app's OAuth2 settings.
# Must point to the API server's callback route.
# e.g. https://api.yourdomain.com/api/auth/discord/callback
DISCORD_REDIRECT_URI=https://api.yourdomain.com/api/auth/discord/callback

# NS Auth API key from ns.com/platform (format: nsauth_...)
# Used to verify that the Discord user is an NS member.
NS_AUTH_API_KEY=nsauth_...

# Discord bot token — discord.com/developers → your app → Bot → Token
# No special intents or server invite required. Users DM the bot directly.
DISCORD_BOT_TOKEN=

# Secret used to sign JWTs issued after successful login.
# Use a long random string: openssl rand -hex 32
SESSION_SECRET=

# --- Web frontend (Vite build-time) ---
# Base URL of the API server, used for the Discord OAuth redirect link.
# Leave blank if the frontend and API are on the same origin (e.g. proxied).
# e.g. https://api.yourdomain.com
VITE_API_URL=


# ------------------------------------------------------------
# OPENAI / LLM
# ------------------------------------------------------------

# OpenAI API key
OPENAI_API_KEY=sk-...

# Override the OpenAI base URL (optional).
# Leave blank to use the default https://api.openai.com/v1
# Set to a compatible proxy (e.g. Azure OpenAI, LiteLLM, etc.) if needed.
OPENAI_BASE_URL=


# ------------------------------------------------------------
# OBJECT STORAGE  (Google Cloud Storage)
# ------------------------------------------------------------
# The API server authenticates via Application Default Credentials (ADC) or
# a service account key file when not running on Replit.
# Set GOOGLE_APPLICATION_CREDENTIALS to your service account JSON path, or
# configure workload identity / ADC on your host.

# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# The GCS bucket + path where private uploads are stored.
# Format: /bucket-name/optional/prefix
# Example: /my-app-uploads/private
PRIVATE_OBJECT_DIR=/your-bucket/private

# Comma-separated list of GCS paths to search for public assets.
# These are served without authentication via /api/storage/public-objects/*
# Example: /my-app-uploads/public
PUBLIC_OBJECT_SEARCH_PATHS=/your-bucket/public


# ------------------------------------------------------------
# PUBLIC URLS
# The API server needs to know its own public address to:
#   - register the Telegram webhook on startup
#   - build Hub post deep links for Telegram messages
#   - build iCal subscribe URLs
# ------------------------------------------------------------

# Publicly reachable base URL of the API server (no trailing slash)
# e.g. https://api.yourdomain.com
PUBLIC_API_URL=https://api.yourdomain.com

# Publicly reachable base URL of the web frontend (no trailing slash)
# Used in Hub notification deep links sent to Telegram.
# e.g. https://app.yourdomain.com
PUBLIC_APP_URL=https://app.yourdomain.com


# ------------------------------------------------------------
# CORS  (production only)
# Required when the frontend and API are on different origins.
# Comma-separated list of allowed origins.
# Leave blank to allow all origins (development / same-domain only).
# ------------------------------------------------------------
ALLOWED_ORIGINS=https://app.yourdomain.com


# ------------------------------------------------------------
# TELEGRAM BOT  (optional)
# Create a bot via @BotFather on Telegram to get a token.
# Without this the Telegram integration is simply disabled.
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=


